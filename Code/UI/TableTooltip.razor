@using Sandbox;
@using Sandbox.UI;
@using TerrysCasino.Games.Poker;
@inherits PanelComponent

<root>
	@if ( ShowTooltip )
	{
		<div class="table-tooltip">
			<span class="tooltip-text">Press E to sit</span>
			<span class="tooltip-seats">@SeatsText</span>
		</div>
	}
</root>

<style>
	.table-tooltip {
		position: absolute;
		bottom: 30%;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
		background-color: rgba(0, 0, 0, 0.7);
		border: 1px solid rgba(212, 175, 55, 0.5);
		border-radius: 6px;
		padding: 8px 16px;
		pointer-events: none;
	}

	.tooltip-text {
		font-family: Poppins;
		font-size: 16px;
		color: white;
		font-weight: bold;
	}

	.tooltip-seats {
		font-family: Poppins;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.6);
	}

	.tooltip-seats.full { color: #e74c3c; }
</style>

@code {
	private bool ShowTooltip
	{
		get
		{
			var interaction = Scene?.GetAllComponents<PokerTableInteraction>()
				?.FirstOrDefault( t => t.IsLocalPlayerInRange() );
			return interaction != null;
		}
	}

	private string SeatsText
	{
		get
		{
			var table = Scene?.GetAllComponents<PokerTable>()?.FirstOrDefault();
			if ( table == null ) return "";
			if ( table.OccupiedSeats >= table.SeatCount )
				return "FULL";
			return $"{table.OccupiedSeats}/{table.SeatCount} seats";
		}
	}

	protected override int BuildHash() => System.HashCode.Combine( ShowTooltip, SeatsText );
}
